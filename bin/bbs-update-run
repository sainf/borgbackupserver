#!/usr/bin/env bash
#
# BBS Update Run — executes all post-pull update steps.
#
# Called by bbs-update after code has been pulled. Because bbs-update exec's
# this script, it always runs the freshly-pulled version regardless of what
# version of bbs-update the user originally invoked.
#
# Usage (internal — called by bbs-update):
#   bash /var/www/bbs/bin/bbs-update-run <bbs_dir>
#
set -euo pipefail

BBS_DIR="${1:-/var/www/bbs}"

# 2. Install/update PHP dependencies
echo "[2/9] Installing PHP dependencies..."
if command -v composer &>/dev/null; then
    composer install --no-dev --working-dir="$BBS_DIR" --quiet
else
    echo "  Warning: composer not found, skipping"
fi

# 3. Fix web file ownership
echo "[3/9] Setting web file permissions..."
chown -R www-data:www-data "$BBS_DIR"
chmod 755 "$BBS_DIR/config"
[ -f "$BBS_DIR/config/.env" ] && chmod 600 "$BBS_DIR/config/.env"

# 4. Update SSH helper and gate
echo "[4/9] Updating SSH helper..."
cp "$BBS_DIR/bin/bbs-ssh-helper" /usr/local/bin/bbs-ssh-helper
chmod 755 /usr/local/bin/bbs-ssh-helper
/usr/local/bin/bbs-ssh-helper install-gate
/usr/local/bin/bbs-ssh-helper update-all-keys

# 4b. Set PHP max_execution_time (default 30s is too short for large operations)
PHP_INI_DIR=$(php -r 'echo php_ini_scanned_dir();' 2>/dev/null)
if [ -n "$PHP_INI_DIR" ] && [ -d "$PHP_INI_DIR" ]; then
    echo "max_execution_time = 300" > "$PHP_INI_DIR/bbs.ini"
fi

# 5. ClickHouse — ensure running and schema is current
echo "[5/9] Checking ClickHouse..."
if command -v clickhouse-server &>/dev/null; then
    # Ensure config override is in place
    mkdir -p /etc/clickhouse-server/config.d
    if [ -f "$BBS_DIR/config/clickhouse-server-override.xml" ]; then
        cp "$BBS_DIR/config/clickhouse-server-override.xml" /etc/clickhouse-server/config.d/bbs-override.xml
    fi
    # Ensure service is running
    systemctl is-active --quiet clickhouse-server || systemctl start clickhouse-server 2>/dev/null || true
    # Ensure database and tables exist (idempotent)
    clickhouse-client --query "CREATE DATABASE IF NOT EXISTS bbs" 2>/dev/null || true
    clickhouse-client -d bbs --multiquery < "$BBS_DIR/schema-clickhouse.sql" 2>/dev/null || true
    echo "  OK"
else
    echo "  Warning: ClickHouse not installed (catalog features unavailable)"
    echo "  Run the installer to set up ClickHouse, or reinstall BBS."
fi

# 6. Fix runtime directories and SSH permissions
echo "[6/9] Fixing permissions..."

# Borg cache dir for www-data
mkdir -p /var/bbs/cache/www-data
chown www-data:www-data /var/bbs/cache/www-data

# Fix per-user home and .ssh permissions (required for sshd StrictModes)
for user in $(getent passwd | grep '^bbs-' | cut -d: -f1); do
    home=$(getent passwd "$user" | cut -d: -f6)

    # Per-user borg cache dir
    borgdir="/var/bbs/cache/$user"
    mkdir -p "$borgdir"
    chown "$user":"$user" "$borgdir"

    # Home dir: 750 for sshd compatibility, owned by user with www-data group
    if [ -d "$home" ]; then
        chown "$user":www-data "$home"
        chmod 750 "$home"

        # .ssh dir strict ownership
        if [ -d "$home/.ssh" ]; then
            chown -R "$user":"$user" "$home/.ssh"
            chmod 700 "$home/.ssh"
            [ -f "$home/.ssh/authorized_keys" ] && chmod 600 "$home/.ssh/authorized_keys"
        fi
    fi
done

# 7. Verify sudoers
echo "[7/9] Verifying sudoers..."
SUDOERS_FILE="/etc/sudoers.d/bbs-ssh-helper"
EXPECTED="www-data ALL=(root) NOPASSWD: /usr/local/bin/bbs-ssh-helper, $BBS_DIR/bin/bbs-update"
if [ ! -f "$SUDOERS_FILE" ] || ! grep -q "bbs-update" "$SUDOERS_FILE"; then
    echo "$EXPECTED" > "$SUDOERS_FILE"
    chmod 440 "$SUDOERS_FILE"
    echo "  Updated"
else
    echo "  OK"
fi

BORG_SUDOERS="/etc/sudoers.d/bbs-borg"
BORG_EXPECTED="www-data ALL=(bbs-*) NOPASSWD: /usr/bin/borg, /usr/local/bin/borg, /usr/bin/rclone, /usr/bin/env"
if [ ! -f "$BORG_SUDOERS" ] || ! grep -q "/usr/bin/rclone" "$BORG_SUDOERS"; then
    echo "$BORG_EXPECTED" > "$BORG_SUDOERS"
    chmod 440 "$BORG_SUDOERS"
fi

# 8. Run database migrations
echo "[8/9] Running database migrations..."
sudo -u www-data php "$BBS_DIR/migrate.php" 2>&1 || echo "  Warning: migration runner returned an error (migrations may run on next page load)"

# 9. Fix storage path permissions
echo "[9/9] Fixing storage path permissions..."
ENV_FILE="$BBS_DIR/config/.env"
if [ -f "$ENV_FILE" ]; then
    DB_HOST=$(grep '^DB_HOST=' "$ENV_FILE" | cut -d= -f2-)
    DB_NAME=$(grep '^DB_NAME=' "$ENV_FILE" | cut -d= -f2-)
    DB_USER=$(grep '^DB_USER=' "$ENV_FILE" | cut -d= -f2-)
    DB_PASS=$(grep '^DB_PASS=' "$ENV_FILE" | cut -d= -f2-)

    if [ -n "$DB_NAME" ] && [ -n "$DB_USER" ]; then
        STORAGE_PATH=$(mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" \
            -N -e "SELECT \`value\` FROM settings WHERE \`key\` = 'storage_path'" 2>/dev/null || true)

        if [ -n "$STORAGE_PATH" ]; then
            if [ ! -d "$STORAGE_PATH" ]; then
                mkdir -p "$STORAGE_PATH"
                echo "  Created $STORAGE_PATH"
            fi
            chown root:www-data "$STORAGE_PATH"
            chmod 775 "$STORAGE_PATH"
            echo "  Fixed $STORAGE_PATH"
        else
            echo "  No storage path configured"
        fi
    else
        echo "  Warning: could not read DB credentials from .env"
    fi
else
    echo "  Warning: .env not found, skipping"
fi

# Restart PHP to clear OPcache
PHP_FPM=$(systemctl list-units --type=service --no-legend 2>/dev/null | grep -oP 'php[0-9.]+-fpm\.service' | head -1 || true)
if [ -n "$PHP_FPM" ]; then
    systemctl restart "$PHP_FPM"
else
    systemctl restart php-fpm 2>/dev/null || true
fi

echo ""
echo "=== Update complete ==="
