#!/usr/bin/env bash
#
# bbs-ssh-gate -- SSH command dispatcher for BBS agent connections.
#
# Installed as the forced command in authorized_keys for all bbs-* users.
# Inspects SSH_ORIGINAL_COMMAND to dispatch to either borg serve or
# a sandboxed catalog log writer.
#
# authorized_keys format:
#   command="/usr/local/bin/bbs-ssh-gate /var/bbs/home/3",restrict ssh-ed25519 AAAA...
#
# The .catalog-logs directory is pre-created by bbs-ssh-helper create-user
# with setgid www-data, so new files automatically get www-data group.
#
set -euo pipefail

HOME_DIR="${1:-}"

if [[ -z "$HOME_DIR" ]]; then
    echo "ERROR: no home directory specified" >&2
    exit 1
fi

case "${SSH_ORIGINAL_COMMAND:-}" in
    "borg serve"*)
        # Normal borg operations -- pass through to borg serve with append-only
        # Build restrict-to-path args: always include home dir, plus any extra
        # storage locations listed in .storage-paths (one path per line)
        RESTRICT_ARGS=(--restrict-to-path "$HOME_DIR")
        if [[ -f "$HOME_DIR/.storage-paths" ]]; then
            while IFS= read -r extra_path; do
                [[ -n "$extra_path" ]] && RESTRICT_ARGS+=(--restrict-to-path "$extra_path")
            done < "$HOME_DIR/.storage-paths"
        fi
        exec borg serve --append-only "${RESTRICT_ARGS[@]}"
        ;;

    "catalog-write "*)
        # Catalog log streaming -- write stdin to a sandboxed log file
        JOB_ID="${SSH_ORIGINAL_COMMAND#catalog-write }"

        # Validate job_id is numeric only (prevent path traversal)
        if [[ ! "$JOB_ID" =~ ^[0-9]+$ ]]; then
            echo "ERROR: invalid job_id" >&2
            exit 1
        fi

        LOG_DIR="$HOME_DIR/.catalog-logs"

        # Directory should already exist (created by bbs-ssh-helper with setgid).
        # Create if missing (first backup before server update applied the dir).
        mkdir -p "$LOG_DIR" 2>/dev/null || true

        TARGET="$LOG_DIR/catalog-${JOB_ID}.jsonl"

        # Diagnostic log for troubleshooting FUSE/shfs permission issues (#84)
        DIAG_LOG="$LOG_DIR/.catalog-diag.log"
        {
            echo "=== catalog-write job=$JOB_ID $(date -Iseconds) ==="
            echo "user=$(id)"
            echo "target=$TARGET"
            echo "dir_perms=$(stat -c '%A %U:%G' "$LOG_DIR" 2>&1)"
            echo "mount=$(stat -f -c '%T' "$LOG_DIR" 2>/dev/null || mount | grep "$(df "$LOG_DIR" --output=source 2>/dev/null | tail -1)" 2>/dev/null | head -1 || echo 'unknown')"
        } >> "$DIAG_LOG" 2>&1 || true

        cat > "$TARGET"

        # Log file state immediately after creation (before any chmod/chgrp)
        {
            echo "created: $(stat -c '%A %U:%G %s bytes' "$TARGET" 2>&1)"
        } >> "$DIAG_LOG" 2>&1 || true

        # Make sure www-data (the web server user that imports the catalog)
        # can read the file. We can't rely on the parent directory's setgid
        # bit alone — FUSE filesystems like Unraid's shfs don't always honor
        # setgid for new files, leaving the file in the bbs-* user's primary
        # group which www-data has no access to. Explicitly chgrp to
        # www-data; the bbs-* user is added to the www-data supplementary
        # group at create time so this is allowed without root.
        if chgrp www-data "$TARGET" 2>/dev/null; then
            chmod 640 "$TARGET" 2>/dev/null || true
            echo "chgrp=ok final=$(stat -c '%A %U:%G' "$TARGET" 2>&1)" >> "$DIAG_LOG" 2>&1 || true
        else
            # Fallback for setups where chgrp to www-data failed (existing
            # users created before the supplementary-group fix, or filesystems
            # that map ownership through a translation layer): make the file
            # world-readable so www-data can import it via "other" permissions.
            chmod 644 "$TARGET" 2>/dev/null || true
            echo "chgrp=FAILED fallback=644 final=$(stat -c '%A %U:%G' "$TARGET" 2>&1)" >> "$DIAG_LOG" 2>&1 || true
        fi
        ;;

    "ping")
        # Simple connectivity test for agent self-diagnosis
        echo "pong"
        ;;

    *)
        echo "ERROR: command not allowed" >&2
        exit 1
        ;;
esac
