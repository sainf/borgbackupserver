#!/usr/bin/env bash
#
# BBS Update Script — pulls latest code and updates all components.
#
# Usage:
#   sudo /var/www/bbs/bin/bbs-update
#
set -euo pipefail

BBS_DIR="${1:-/var/www/bbs}"
GIT_TAG="${2:-}"

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: must run as root (use sudo)"
    exit 1
fi

if [ ! -d "$BBS_DIR" ]; then
    echo "Error: BBS directory not found at $BBS_DIR"
    exit 1
fi

echo "=== BBS Update ==="
echo ""

git config --global --add safe.directory "$BBS_DIR" 2>/dev/null || true

# 1. Pull / checkout code
if [ -n "$GIT_TAG" ]; then
    echo "[1/8] Upgrading to $GIT_TAG..."
    git -C "$BBS_DIR" fetch --all --tags --force
    git -C "$BBS_DIR" checkout main 2>/dev/null || true
    if [ "$GIT_TAG" = "main" ]; then
        git -C "$BBS_DIR" reset --hard origin/main
    else
        git -C "$BBS_DIR" reset --hard "$GIT_TAG"
    fi
else
    echo "[1/8] Checking for latest release..."
    git -C "$BBS_DIR" fetch --all --tags --force
    LATEST_TAG=$(git -C "$BBS_DIR" tag --sort=-v:refname | grep -E '^v[0-9]' | head -1)
    if [ -n "$LATEST_TAG" ]; then
        echo "  Upgrading to $LATEST_TAG"
        git -C "$BBS_DIR" checkout main 2>/dev/null || true
        git -C "$BBS_DIR" reset --hard "$LATEST_TAG"
    else
        echo "  No release tags found, pulling main"
        git -C "$BBS_DIR" checkout main 2>/dev/null || true
        git -C "$BBS_DIR" pull
    fi
fi

# 2. Install/update PHP dependencies
echo "[2/8] Installing PHP dependencies..."
if command -v composer &>/dev/null; then
    composer install --no-dev --working-dir="$BBS_DIR" --quiet
else
    echo "  Warning: composer not found, skipping"
fi

# 3. Fix web file ownership
echo "[3/8] Setting web file permissions..."
chown -R www-data:www-data "$BBS_DIR"
chmod 755 "$BBS_DIR/config"
[ -f "$BBS_DIR/config/.env" ] && chmod 600 "$BBS_DIR/config/.env"

# 4. Update SSH helper
echo "[4/8] Updating SSH helper..."
cp "$BBS_DIR/bin/bbs-ssh-helper" /usr/local/bin/bbs-ssh-helper
chmod 755 /usr/local/bin/bbs-ssh-helper

# 5. Fix runtime directories
echo "[5/8] Fixing runtime permissions..."

# Borg cache dirs under /var/bbs/cache (avoid /tmp size limits)
mkdir -p /var/bbs/cache/www-data
chown www-data:www-data /var/bbs/cache/www-data

# Fix permissions for each bbs-* user's borg dir and home
for user in $(getent passwd | grep '^bbs-' | cut -d: -f1); do
    home=$(getent passwd "$user" | cut -d: -f6)

    # Per-user borg cache dir
    borgdir="/var/bbs/cache/$user"
    mkdir -p "$borgdir"
    chown "$user":"$user" "$borgdir"

    # Home dir: 750 for sshd compatibility, owned by user with www-data group
    if [ -d "$home" ]; then
        chown "$user":www-data "$home"
        chmod 750 "$home"

        # .ssh dir strict ownership
        if [ -d "$home/.ssh" ]; then
            chown -R "$user":"$user" "$home/.ssh"
            chmod 700 "$home/.ssh"
            [ -f "$home/.ssh/authorized_keys" ] && chmod 600 "$home/.ssh/authorized_keys"
        fi

        # Repo directories: owned by user, group www-data, 770
        for repo in "$home"/*/; do
            [ -d "$repo" ] || continue
            # Skip .ssh
            [ "$(basename "$repo")" = ".ssh" ] && continue
            chown -R "$user":www-data "$repo"
            chmod 770 "$repo"
        done
    fi
done

# 6. Fix sudoers (ensure bbs-update is allowed)
echo "[6/8] Verifying sudoers..."
SUDOERS_FILE="/etc/sudoers.d/bbs-ssh-helper"
EXPECTED="www-data ALL=(root) NOPASSWD: /usr/local/bin/bbs-ssh-helper, $BBS_DIR/bin/bbs-update"
if [ -f "$SUDOERS_FILE" ]; then
    if ! grep -q "bbs-update" "$SUDOERS_FILE"; then
        echo "$EXPECTED" > "$SUDOERS_FILE"
        chmod 440 "$SUDOERS_FILE"
        echo "  Updated sudoers to include bbs-update"
    else
        echo "  OK"
    fi
else
    echo "$EXPECTED" > "$SUDOERS_FILE"
    chmod 440 "$SUDOERS_FILE"
    echo "  Created sudoers file"
fi

# Ensure borg sudoers rule exists (allows prune/compact as client users)
BORG_SUDOERS="/etc/sudoers.d/bbs-borg"
BORG_EXPECTED="www-data ALL=(bbs-*) NOPASSWD: /usr/bin/borg, /usr/bin/env"
if [ ! -f "$BORG_SUDOERS" ] || ! grep -q "bbs-\*" "$BORG_SUDOERS"; then
    echo "$BORG_EXPECTED" > "$BORG_SUDOERS"
    chmod 440 "$BORG_SUDOERS"
    echo "  Created borg sudoers rule"
fi

# 7. Run database migrations
echo "[7/8] Running database migrations..."
sudo -u www-data php "$BBS_DIR/migrate.php" 2>&1 || echo "  Warning: migration runner returned an error (migrations may run on next page load)"

# 8. Fix storage path permissions
echo "[8/8] Fixing storage path permissions..."
ENV_FILE="$BBS_DIR/config/.env"
if [ -f "$ENV_FILE" ]; then
    DB_HOST=$(grep '^DB_HOST=' "$ENV_FILE" | cut -d= -f2-)
    DB_NAME=$(grep '^DB_NAME=' "$ENV_FILE" | cut -d= -f2-)
    DB_USER=$(grep '^DB_USER=' "$ENV_FILE" | cut -d= -f2-)
    DB_PASS=$(grep '^DB_PASS=' "$ENV_FILE" | cut -d= -f2-)

    if [ -n "$DB_NAME" ] && [ -n "$DB_USER" ]; then
        STORAGE_PATH=$(mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" \
            -N -e "SELECT \`value\` FROM settings WHERE \`key\` = 'storage_path'" 2>/dev/null || true)

        if [ -n "$STORAGE_PATH" ]; then
            if [ ! -d "$STORAGE_PATH" ]; then
                mkdir -p "$STORAGE_PATH"
                echo "  Created $STORAGE_PATH"
            fi
            # root-owned with www-data group so sshd StrictModes
            # doesn't reject user homes underneath this path
            chown root:www-data "$STORAGE_PATH"
            chmod 775 "$STORAGE_PATH"
            echo "  Fixed $STORAGE_PATH"
        else
            echo "  No storage path configured"
        fi
    else
        echo "  Warning: could not read DB credentials from .env"
    fi
else
    echo "  Warning: .env not found, skipping"
fi

# Restart PHP-FPM to clear OPcache (CLI opcache_reset won't affect FPM)
PHP_FPM=$(systemctl list-units --type=service --no-legend 2>/dev/null | grep -oP 'php[0-9.]+-fpm\.service' | head -1 || true)
if [ -n "$PHP_FPM" ]; then
    echo "  Restarting $PHP_FPM..."
    systemctl restart "$PHP_FPM"
else
    # Try generic service name
    systemctl restart php-fpm 2>/dev/null || true
fi

echo ""
echo "=== Update complete ==="
