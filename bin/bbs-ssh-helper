#!/usr/bin/env bash
#
# BBS SSH Helper — runs as root via sudo to manage Unix users for borg SSH access.
#
# Usage:
#   bbs-ssh-helper create-user <username> <home_dir> <public_key>
#   bbs-ssh-helper create-repo-dir <repo_dir>
#   bbs-ssh-helper borg-init <repo_path> <encryption> [passphrase]
#   bbs-ssh-helper delete-user <username>
#   bbs-ssh-helper install-gate
#   bbs-ssh-helper update-all-keys
#
# Install:
#   cp bin/bbs-ssh-helper /usr/local/bin/bbs-ssh-helper
#   chmod 755 /usr/local/bin/bbs-ssh-helper
#   echo "www-data ALL=(root) NOPASSWD: /usr/local/bin/bbs-ssh-helper, /var/www/bbs/bin/bbs-update" > /etc/sudoers.d/bbs-ssh-helper
#
set -euo pipefail

ACTION="${1:-}"

# Check if a path is under /var/bbs/ or a registered storage location
is_allowed_path() {
    local CHECK_PATH="$1"
    [[ "$CHECK_PATH" =~ ^/var/bbs/ ]] && return 0
    if [ -f /etc/bbs/allowed-storage-paths ]; then
        while IFS= read -r allowed_path; do
            [[ -n "$allowed_path" ]] && [[ "$CHECK_PATH" =~ ^"$allowed_path"/ ]] && return 0
        done < /etc/bbs/allowed-storage-paths
    fi
    return 1
}

case "$ACTION" in
    create-user)
        USERNAME="${2:-}"
        HOME_DIR="${3:-}"
        PUBLIC_KEY="${4:-}"

        if [ -z "$USERNAME" ] || [ -z "$HOME_DIR" ] || [ -z "$PUBLIC_KEY" ]; then
            echo "Usage: bbs-ssh-helper create-user <username> <home_dir> <public_key>"
            exit 1
        fi

        # Validate username format (must start with bbs-)
        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Create home directory if needed
        mkdir -p "$HOME_DIR"

        # Create user with no password, no login shell, home at storage path
        if id "$USERNAME" &>/dev/null; then
            echo "User $USERNAME already exists"
        else
            useradd --shell /bin/sh --home-dir "$HOME_DIR" --no-create-home "$USERNAME"
            echo "Created user: $USERNAME"
        fi

        # Set ownership: user owns, www-data group for server-side borg operations (init, prune, compact)
        chown "$USERNAME":www-data "$HOME_DIR"
        chmod 750 "$HOME_DIR"

        # Configure SSH authorized_keys with gate dispatcher
        SSH_DIR="$HOME_DIR/.ssh"
        mkdir -p "$SSH_DIR"
        chmod 700 "$SSH_DIR"

        AUTHORIZED_KEYS="$SSH_DIR/authorized_keys"
        RESTRICT_CMD="command=\"/usr/local/bin/bbs-ssh-gate $HOME_DIR\",restrict"

        echo "$RESTRICT_CMD $PUBLIC_KEY" > "$AUTHORIZED_KEYS"
        chmod 600 "$AUTHORIZED_KEYS"
        chown -R "$USERNAME":"$USERNAME" "$SSH_DIR"

        # Create catalog log directory with setgid so files inherit www-data group
        CATALOG_DIR="$HOME_DIR/.catalog-logs"
        mkdir -p "$CATALOG_DIR"
        chown "$USERNAME":www-data "$CATALOG_DIR"
        chmod 2770 "$CATALOG_DIR"

        echo "OK"
        ;;

    create-repo-dir)
        REPO_DIR="${2:-}"

        if [ -z "$REPO_DIR" ]; then
            echo "Usage: bbs-ssh-helper create-repo-dir <repo_dir>"
            exit 1
        fi

        if ! is_allowed_path "$REPO_DIR"; then
            echo "Error: repo dir must be under /var/bbs/ or a registered storage location"
            exit 1
        fi

        # Check if parent needs to be created (e.g., /var/bbs/home/3/ for user's home)
        PARENT_DIR=$(dirname "$REPO_DIR")
        if [ ! -d "$PARENT_DIR" ]; then
            # Parent doesn't exist - need to create and set ownership
            # For paths like /var/bbs/home/3/reponame, the parent is the user's home
            mkdir -p "$PARENT_DIR"
        fi

        # Create the repo directory
        mkdir -p "$REPO_DIR"

        # Find the bbs-* user who owns the parent directory.
        # On NFS with admin mapping, stat may return UNKNOWN or the NFS-mapped user,
        # so we also search by path when the owner isn't a bbs-* user.
        PARENT_OWNER=$(stat -c '%U' "$PARENT_DIR")

        if [[ ! "$PARENT_OWNER" =~ ^bbs- ]]; then
            # Parent not owned by a bbs-* user (could be root, UNKNOWN, or NFS-mapped).
            # Try to find the correct bbs-* user by matching the directory path.
            ACTUAL_USER=$(awk -F: -v home="$PARENT_DIR" '$6 == home && $1 ~ /^bbs-/ {print $1}' /etc/passwd)
            if [ -z "$ACTUAL_USER" ]; then
                BASENAME=$(basename "$PARENT_DIR")
                if [[ "$BASENAME" =~ ^[0-9]+$ ]]; then
                    ACTUAL_USER=$(awk -F: -v aid="/$BASENAME" '$6 ~ aid"$" && $1 ~ /^bbs-/ {print $1}' /etc/passwd)
                fi
            fi
            if [ -n "$ACTUAL_USER" ]; then
                PARENT_OWNER="$ACTUAL_USER"
            fi
        fi

        # Set ownership (may fail on NFS with admin mapping — non-fatal)
        if [[ "$PARENT_OWNER" =~ ^bbs- ]]; then
            chown "$PARENT_OWNER":www-data "$PARENT_DIR" 2>/dev/null || true
            chmod 750 "$PARENT_DIR" 2>/dev/null || true
            chown "$PARENT_OWNER":www-data "$REPO_DIR" 2>/dev/null || true
        fi
        chmod 770 "$REPO_DIR" 2>/dev/null || true
        echo "OK"
        ;;

    borg-extract)
        # Run borg extract as the repo-owning user
        # Usage: bbs-ssh-helper borg-extract <username> <tmpdir> <passphrase> <repo::archive> [paths...]
        USERNAME="${2:-}"
        TMPDIR="${3:-}"
        PASSPHRASE="${4:-}"
        shift 4 2>/dev/null || true

        if [ -z "$USERNAME" ] || [ -z "$TMPDIR" ] || [ $# -eq 0 ]; then
            echo "Usage: bbs-ssh-helper borg-extract <username> <tmpdir> <passphrase> <repo::archive> [paths...]"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Safety: tmpdir must be under /tmp
        if [[ ! "$TMPDIR" =~ ^/tmp/ ]]; then
            echo "Error: tmpdir must be under /tmp/"
            exit 1
        fi

        # Ensure tmpdir exists and is writable by the user
        mkdir -p "$TMPDIR"
        chown "$USERNAME":www-data "$TMPDIR"
        chmod 770 "$TMPDIR"

        # Per-user borg cache dir (matches scheduler.php and bbs-update)
        BORG_DIR="/var/bbs/cache/$USERNAME"
        mkdir -p "$BORG_DIR"
        chown "$USERNAME":"$USERNAME" "$BORG_DIR"

        # Run borg extract as the repo-owning user
        cd "$TMPDIR"
        sudo -u "$USERNAME" \
            BORG_PASSPHRASE="$PASSPHRASE" \
            BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
            BORG_RELOCATED_REPO_ACCESS_IS_OK=yes \
            BORG_BASE_DIR="$BORG_DIR" \
            HOME="$BORG_DIR" \
            borg extract "$@" 2>&1

        EXIT_CODE=$?

        # Make extracted files readable by www-data for tar/streaming
        # Redirect to /dev/null to avoid SIGPIPE if caller closed the pipe
        chown -R "$USERNAME":www-data "$TMPDIR" >/dev/null 2>&1
        find "$TMPDIR" -type d -exec chmod 770 {} + >/dev/null 2>&1
        find "$TMPDIR" -type f -exec chmod 660 {} + >/dev/null 2>&1

        exit $EXIT_CODE
        ;;

    verify-repo)
        # Verify a borg repo exists and return JSON (encryption mode, archive list).
        # Runs as root since repo may have arbitrary ownership before import.
        # Usage: bbs-ssh-helper verify-repo <passphrase> <repo_path>
        PASSPHRASE="${2:-}"
        REPO_PATH="${3:-}"

        if [ -z "$REPO_PATH" ]; then
            echo "Usage: bbs-ssh-helper verify-repo <passphrase> <repo_path>"
            exit 1
        fi

        if ! is_allowed_path "$REPO_PATH"; then
            echo "Error: repo path must be under /var/bbs/ or a registered storage location"
            exit 1
        fi

        mkdir -p /tmp/bbs-verify

        BORG_PASSPHRASE="$PASSPHRASE" \
        BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
        BORG_RELOCATED_REPO_ACCESS_IS_OK=yes \
        BORG_BASE_DIR="/tmp/bbs-verify" \
        HOME="/tmp/bbs-verify" \
            borg list --json "$REPO_PATH" 2>&1

        exit $?
        ;;

    borg-list)
        # Run borg list as the repo-owning user
        # Usage: bbs-ssh-helper borg-list <username> <passphrase> <repo_path>
        USERNAME="${2:-}"
        PASSPHRASE="${3:-}"
        REPO_PATH="${4:-}"

        if [ -z "$USERNAME" ] || [ -z "$REPO_PATH" ]; then
            echo "Usage: bbs-ssh-helper borg-list <username> <passphrase> <repo_path>"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        if ! is_allowed_path "$REPO_PATH"; then
            echo "Error: repo path must be under /var/bbs/ or a registered storage location"
            exit 1
        fi

        # Per-user borg cache dir
        BORG_DIR="/var/bbs/cache/$USERNAME"
        mkdir -p "$BORG_DIR"
        chown "$USERNAME":"$USERNAME" "$BORG_DIR"

        # Run borg list --json as the repo-owning user
        # Do NOT use 2>&1 here — borg warnings on stderr corrupt the JSON output
        # and cause json_decode to fail, which can wipe all archive records.
        sudo -u "$USERNAME" \
            BORG_PASSPHRASE="$PASSPHRASE" \
            BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
            BORG_RELOCATED_REPO_ACCESS_IS_OK=yes \
            BORG_BASE_DIR="$BORG_DIR" \
            HOME="$BORG_DIR" \
            borg list --json "$REPO_PATH"

        exit $?
        ;;

    borg-list-archive)
        # List files in a specific archive (for catalog rebuild)
        # Usage: bbs-ssh-helper borg-list-archive <username> <passphrase> <repo_path>::<archive_name>
        # Output: JSON array of file paths
        USERNAME="${2:-}"
        PASSPHRASE="${3:-}"
        ARCHIVE_PATH="${4:-}"

        if [ -z "$USERNAME" ] || [ -z "$ARCHIVE_PATH" ]; then
            echo "Usage: bbs-ssh-helper borg-list-archive <username> <passphrase> <repo::archive>"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Extract repo path from archive path (before ::)
        REPO_PATH="${ARCHIVE_PATH%%::*}"

        if ! is_allowed_path "$REPO_PATH"; then
            echo "Error: repo path must be under /var/bbs/ or a registered storage location"
            exit 1
        fi

        # Per-user borg cache dir
        BORG_DIR="/var/bbs/cache/$USERNAME"
        mkdir -p "$BORG_DIR"
        chown "$USERNAME":"$USERNAME" "$BORG_DIR"

        # Run borg list on archive with JSON output (paths only)
        sudo -u "$USERNAME" \
            BORG_PASSPHRASE="$PASSPHRASE" \
            BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
            BORG_RELOCATED_REPO_ACCESS_IS_OK=yes \
            BORG_BASE_DIR="$BORG_DIR" \
            HOME="$BORG_DIR" \
            borg list --json-lines "$ARCHIVE_PATH" 2>&1

        exit $?
        ;;

    borg-cmd)
        # Run arbitrary borg command as the repo-owning user
        # Usage: bbs-ssh-helper borg-cmd <username> <passphrase> <borg-subcommand> [args...]
        # Example: bbs-ssh-helper borg-cmd bbs-3 "secret" compact /var/bbs/home/3/repo
        # Example: bbs-ssh-helper borg-cmd bbs-3 "secret" check --verbose /var/bbs/home/3/repo
        USERNAME="${2:-}"
        PASSPHRASE="${3:-}"
        shift 3 2>/dev/null || true
        # Remaining args are the borg subcommand and its arguments

        if [ -z "$USERNAME" ] || [ $# -eq 0 ]; then
            echo "Usage: bbs-ssh-helper borg-cmd <username> <passphrase> <borg-subcommand> [args...]"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Validate that at least one arg is an allowed path
        FOUND_ALLOWED_PATH=false
        for arg in "$@"; do
            if is_allowed_path "$arg"; then
                FOUND_ALLOWED_PATH=true
                break
            fi
        done
        if [ "$FOUND_ALLOWED_PATH" = false ]; then
            echo "Error: borg command must include a path under /var/bbs/ or a registered storage location"
            exit 1
        fi

        # Per-user borg cache dir
        BORG_DIR="/var/bbs/cache/$USERNAME"
        mkdir -p "$BORG_DIR"
        chown "$USERNAME":"$USERNAME" "$BORG_DIR"

        # Run borg command as the repo-owning user
        sudo -u "$USERNAME" \
            BORG_PASSPHRASE="$PASSPHRASE" \
            BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
            BORG_RELOCATED_REPO_ACCESS_IS_OK=yes \
            BORG_BASE_DIR="$BORG_DIR" \
            HOME="$BORG_DIR" \
            borg "$@" 2>&1

        exit $?
        ;;

    borg-init)
        # Run borg init as root so it works on NFS and other filesystems where
        # www-data may not have write access despite correct POSIX permissions.
        # Usage: bbs-ssh-helper borg-init <repo_path> <encryption> [passphrase]
        REPO_PATH="${2:-}"
        ENCRYPTION="${3:-}"
        PASSPHRASE="${4:-}"

        if [ -z "$REPO_PATH" ] || [ -z "$ENCRYPTION" ]; then
            echo "Usage: bbs-ssh-helper borg-init <repo_path> <encryption> [passphrase]"
            exit 1
        fi

        if ! is_allowed_path "$REPO_PATH"; then
            echo "Error: repo path must be under /var/bbs/ or a registered storage location"
            exit 1
        fi

        # Validate encryption mode
        case "$ENCRYPTION" in
            none|repokey|repokey-blake2|keyfile|keyfile-blake2|authenticated|authenticated-blake2)
                ;;
            *)
                echo "Error: invalid encryption mode: $ENCRYPTION"
                exit 1
                ;;
        esac

        mkdir -p /tmp/bbs-borg-init

        BORG_PASSPHRASE="$PASSPHRASE" \
        BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
        BORG_RELOCATED_REPO_ACCESS_IS_OK=yes \
        BORG_BASE_DIR="/tmp/bbs-borg-init" \
        HOME="/tmp/bbs-borg-init" \
            borg init "--encryption=$ENCRYPTION" "$REPO_PATH" 2>&1

        exit $?
        ;;

    fix-repo-perms)
        REPO_DIR="${2:-}"
        USERNAME="${3:-}"

        if [ -z "$REPO_DIR" ] || [ -z "$USERNAME" ]; then
            echo "Usage: bbs-ssh-helper fix-repo-perms <repo_dir> <username>"
            exit 1
        fi

        if ! is_allowed_path "$REPO_DIR"; then
            echo "Error: repo dir must be under /var/bbs/ or a registered storage location"
            exit 1
        fi
        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        if [ -d "$REPO_DIR" ]; then
            # chown may fail on NFS with admin mapping — non-fatal since
            # all users map to the same NFS user anyway
            chown -R "$USERNAME":www-data "$REPO_DIR" 2>/dev/null || true
            chmod 770 "$REPO_DIR" 2>/dev/null || true
        fi
        echo "OK"
        ;;

    delete-user)
        USERNAME="${2:-}"

        if [ -z "$USERNAME" ]; then
            echo "Usage: bbs-ssh-helper delete-user <username>"
            exit 1
        fi

        # Safety: only delete bbs- prefixed users
        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: will only delete users matching bbs-[a-z0-9_-]+"
            exit 1
        fi

        if id "$USERNAME" &>/dev/null; then
            userdel "$USERNAME" 2>/dev/null || true
            echo "Deleted user: $USERNAME"
        else
            echo "User $USERNAME does not exist"
        fi

        echo "OK"
        ;;

    update-borg)
        # Download and install a borg binary to /usr/local/bin/borg
        # Usage: bbs-ssh-helper update-borg <download_url> <expected_version>
        DOWNLOAD_URL="${2:-}"
        EXPECTED_VERSION="${3:-}"

        if [ -z "$DOWNLOAD_URL" ] || [ -z "$EXPECTED_VERSION" ]; then
            echo "Usage: bbs-ssh-helper update-borg <download_url> <expected_version>"
            exit 1
        fi

        # Safety: only allow downloads from GitHub
        if [[ ! "$DOWNLOAD_URL" =~ ^https://github\.com/borgbackup/borg/releases/ ]]; then
            echo "Error: download URL must be from github.com/borgbackup/borg/releases"
            exit 1
        fi

        BORG_PATH="/usr/local/bin/borg"
        BORG_TMP="/usr/local/bin/borg.tmp"

        # Download binary
        if ! curl -sL -o "$BORG_TMP" "$DOWNLOAD_URL"; then
            rm -f "$BORG_TMP"
            echo "Error: failed to download from $DOWNLOAD_URL"
            exit 1
        fi

        chmod 755 "$BORG_TMP"

        # Verify it runs and outputs expected version
        ACTUAL=$("$BORG_TMP" --version 2>/dev/null || true)
        # Output may be "borg 1.4.3" or "borg.tmp 1.4.3" — extract version number
        ACTUAL_VER=$(echo "$ACTUAL" | grep -oP '[0-9]+\.[0-9]+\.[0-9]+' | head -1)

        if [ "$ACTUAL_VER" != "$EXPECTED_VERSION" ]; then
            rm -f "$BORG_TMP"
            echo "Error: version mismatch — expected $EXPECTED_VERSION, got $ACTUAL_VER"
            exit 1
        fi

        # Backup old binary if it exists at this path
        if [ -f "$BORG_PATH" ]; then
            cp "$BORG_PATH" "${BORG_PATH}.bak"
        fi

        # Atomic replace
        mv "$BORG_TMP" "$BORG_PATH"
        echo "Installed borg $EXPECTED_VERSION to $BORG_PATH"
        echo "OK"
        ;;

    rclone-sync)
        # Run rclone sync as the repo-owning user
        # Usage: bbs-ssh-helper rclone-sync <username> <local_path> <remote> <endpoint> <region> <access_key> <secret_key> [--bwlimit LIMIT]
        USERNAME="${2:-}"
        LOCAL_PATH="${3:-}"
        REMOTE="${4:-}"
        S3_ENDPOINT="${5:-}"
        S3_REGION="${6:-}"
        S3_ACCESS_KEY="${7:-}"
        S3_SECRET_KEY="${8:-}"
        shift 8 2>/dev/null || true
        # Remaining args are optional rclone flags (e.g. --bwlimit 50M)
        EXTRA_ARGS=("$@")

        if [ -z "$USERNAME" ] || [ -z "$LOCAL_PATH" ] || [ -z "$REMOTE" ]; then
            echo "Usage: bbs-ssh-helper rclone-sync <username> <local_path> <remote> <endpoint> <region> <access_key> <secret_key> [rclone flags...]"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Safety: local path must be under /var/bbs/
        if [[ ! "$LOCAL_PATH" =~ ^/var/bbs/ ]]; then
            echo "Error: local path must be under /var/bbs/"
            exit 1
        fi

        # Ensure cache directory exists for the user
        CACHE_DIR="/var/bbs/cache/$USERNAME/rclone"
        mkdir -p "$CACHE_DIR"
        chown -R "$USERNAME":"$USERNAME" "/var/bbs/cache/$USERNAME"

        # Run rclone as the repo-owning user with S3 config via env vars
        # Set HOME and XDG dirs to writable locations to prevent permission errors
        sudo -u "$USERNAME" env \
            "HOME=/var/bbs/cache/$USERNAME" \
            "XDG_CACHE_HOME=$CACHE_DIR" \
            "XDG_CONFIG_HOME=/var/bbs/cache/$USERNAME" \
            "RCLONE_CONFIG=/dev/null" \
            "RCLONE_CONFIG_S3_TYPE=s3" \
            "RCLONE_CONFIG_S3_PROVIDER=Other" \
            "RCLONE_CONFIG_S3_ACCESS_KEY_ID=${S3_ACCESS_KEY}" \
            "RCLONE_CONFIG_S3_SECRET_ACCESS_KEY=${S3_SECRET_KEY}" \
            "RCLONE_CONFIG_S3_ENDPOINT=${S3_ENDPOINT}" \
            "RCLONE_CONFIG_S3_REGION=${S3_REGION}" \
            rclone sync "$LOCAL_PATH" "$REMOTE" \
            --transfers 4 --checkers 8 \
            -v --stats-one-line --stats 5s \
            "${EXTRA_ARGS[@]}" 2>&1

        exit $?
        ;;

    rclone-restore)
        # Run rclone sync FROM S3 TO local (restore)
        # Usage: bbs-ssh-helper rclone-restore <username> <remote> <local_path> <endpoint> <region> <access_key> <secret_key> [--bwlimit LIMIT]
        USERNAME="${2:-}"
        REMOTE="${3:-}"
        LOCAL_PATH="${4:-}"
        S3_ENDPOINT="${5:-}"
        S3_REGION="${6:-}"
        S3_ACCESS_KEY="${7:-}"
        S3_SECRET_KEY="${8:-}"
        shift 8 2>/dev/null || true
        # Remaining args are optional rclone flags (e.g. --bwlimit 50M)
        EXTRA_ARGS=("$@")

        if [ -z "$USERNAME" ] || [ -z "$LOCAL_PATH" ] || [ -z "$REMOTE" ]; then
            echo "Usage: bbs-ssh-helper rclone-restore <username> <remote> <local_path> <endpoint> <region> <access_key> <secret_key> [rclone flags...]"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Safety: local path must be under /var/bbs/
        if [[ ! "$LOCAL_PATH" =~ ^/var/bbs/ ]]; then
            echo "Error: local path must be under /var/bbs/"
            exit 1
        fi

        # Ensure parent directory exists and has correct ownership
        # This handles cases where the user's home dir (/var/bbs/home/N/) might not exist
        PARENT_DIR=$(dirname "$LOCAL_PATH")
        mkdir -p "$PARENT_DIR"
        # Fix ownership if parent is a user home dir owned by root
        if [[ "$PARENT_DIR" =~ ^/var/bbs/home/[0-9]+$ ]]; then
            PARENT_OWNER=$(stat -c '%U' "$PARENT_DIR")
            if [ "$PARENT_OWNER" = "root" ]; then
                chown "$USERNAME":www-data "$PARENT_DIR"
                chmod 750 "$PARENT_DIR"
            fi
        fi

        # Create local directory if needed
        mkdir -p "$LOCAL_PATH"
        chown "$USERNAME":www-data "$LOCAL_PATH"
        chmod 770 "$LOCAL_PATH"

        # Ensure cache directory exists for the user
        CACHE_DIR="/var/bbs/cache/$USERNAME/rclone"
        mkdir -p "$CACHE_DIR"
        chown -R "$USERNAME":"$USERNAME" "/var/bbs/cache/$USERNAME"

        # Run rclone as the repo-owning user with S3 config via env vars
        # Set HOME and XDG dirs to writable locations to prevent permission errors
        # Note: sync FROM remote TO local (reverse of rclone-sync)
        sudo -u "$USERNAME" env \
            "HOME=/var/bbs/cache/$USERNAME" \
            "XDG_CACHE_HOME=$CACHE_DIR" \
            "XDG_CONFIG_HOME=/var/bbs/cache/$USERNAME" \
            "RCLONE_CONFIG=/dev/null" \
            "RCLONE_CONFIG_S3_TYPE=s3" \
            "RCLONE_CONFIG_S3_PROVIDER=Other" \
            "RCLONE_CONFIG_S3_ACCESS_KEY_ID=${S3_ACCESS_KEY}" \
            "RCLONE_CONFIG_S3_SECRET_ACCESS_KEY=${S3_SECRET_KEY}" \
            "RCLONE_CONFIG_S3_ENDPOINT=${S3_ENDPOINT}" \
            "RCLONE_CONFIG_S3_REGION=${S3_REGION}" \
            rclone sync "$REMOTE" "$LOCAL_PATH" \
            --transfers 4 --checkers 8 \
            -v --stats-one-line --stats 5s \
            "${EXTRA_ARGS[@]}" 2>&1

        EXIT_CODE=$?

        # Fix permissions after restore
        chown -R "$USERNAME":www-data "$LOCAL_PATH"
        chmod 770 "$LOCAL_PATH"

        exit $EXIT_CODE
        ;;

    get-size)
        # Get size of a directory in bytes
        # Usage: bbs-ssh-helper get-size <directory>
        DIR="${2:-}"

        if [ -z "$DIR" ]; then
            echo "Usage: bbs-ssh-helper get-size <directory>"
            exit 1
        fi

        if ! is_allowed_path "$DIR"; then
            echo "Error: path must be under /var/bbs/ or a registered storage location"
            exit 1
        fi

        if [ -d "$DIR" ]; then
            du -sb "$DIR" 2>/dev/null | cut -f1
        else
            echo "0"
        fi
        ;;

    delete-storage)
        STORAGE_DIR="${2:-}"

        if [ -z "$STORAGE_DIR" ]; then
            echo "Usage: bbs-ssh-helper delete-storage <directory>"
            exit 1
        fi

        # Safety: refuse to delete system directories
        case "$STORAGE_DIR" in
            /|/bin|/boot|/dev|/etc|/home|/lib*|/opt|/proc|/root|/run|/sbin|/srv|/sys|/tmp|/usr|/var|/var/www|/var/www/bbs)
                echo "Error: refusing to delete system directory: $STORAGE_DIR"
                exit 1
                ;;
        esac

        if [ -d "$STORAGE_DIR" ]; then
            rm -rf "$STORAGE_DIR"
            echo "Removed storage directory: $STORAGE_DIR"
        else
            echo "Directory does not exist: $STORAGE_DIR"
        fi

        echo "OK"
        ;;

    clear-borg-cache)
        # Clear borg cache for a specific user
        # Usage: bbs-ssh-helper clear-borg-cache <username>
        # This is needed after S3 restore to prevent "repository relocated" errors
        # when multiple repos share the same internal borg UUID (common with S3 copies)
        USERNAME="${2:-}"

        if [ -z "$USERNAME" ]; then
            echo "Usage: bbs-ssh-helper clear-borg-cache <username>"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        BORG_CACHE="/var/bbs/cache/$USERNAME/.cache/borg"
        if [ -d "$BORG_CACHE" ]; then
            rm -rf "$BORG_CACHE"
            echo "Cleared borg cache at $BORG_CACHE"
        else
            echo "No borg cache found at $BORG_CACHE"
        fi

        echo "OK"
        ;;

    server-backup)
        # Run the BBS server backup script
        # Usage: bbs-ssh-helper server-backup [--with-catalogs] [--keep N]
        # Creates a backup of the BBS database and config to /var/bbs/backups/
        BACKUP_SCRIPT="/var/www/bbs/bin/bbs-backup"

        if [ ! -f "$BACKUP_SCRIPT" ]; then
            echo "Error: backup script not found at $BACKUP_SCRIPT"
            exit 1
        fi

        # Run the backup script as root, forwarding any extra args
        "$BACKUP_SCRIPT" "${@:2}" 2>&1
        exit $?
        ;;

    rclone-server-sync)
        # Sync server backups to S3
        # Usage: bbs-ssh-helper rclone-server-sync <local_dir> <remote> <endpoint> <region> <access_key> <secret_key>
        # Example: bbs-ssh-helper rclone-server-sync /var/bbs/backups S3:bucket/_server-backups/ s3.wasabisys.com us-east-1 ACCESS SECRET
        LOCAL_DIR="${2:-}"
        REMOTE="${3:-}"
        S3_ENDPOINT="${4:-}"
        S3_REGION="${5:-}"
        S3_ACCESS_KEY="${6:-}"
        S3_SECRET_KEY="${7:-}"

        if [ -z "$LOCAL_DIR" ] || [ -z "$REMOTE" ] || [ -z "$S3_ENDPOINT" ] || [ -z "$S3_ACCESS_KEY" ]; then
            echo "Usage: bbs-ssh-helper rclone-server-sync <local_dir> <remote> <endpoint> <region> <access_key> <secret_key>"
            exit 1
        fi

        # Safety: only allow /var/bbs/backups
        if [[ "$LOCAL_DIR" != "/var/bbs/backups" ]]; then
            echo "Error: local_dir must be /var/bbs/backups"
            exit 1
        fi

        # Ensure cache directory exists
        CACHE_DIR="/var/bbs/cache/server-backup"
        mkdir -p "$CACHE_DIR"

        # Run rclone sync with S3 config via env vars
        env \
            "HOME=$CACHE_DIR" \
            "XDG_CACHE_HOME=$CACHE_DIR" \
            "XDG_CONFIG_HOME=$CACHE_DIR" \
            "RCLONE_CONFIG=/dev/null" \
            "RCLONE_CONFIG_S3_TYPE=s3" \
            "RCLONE_CONFIG_S3_PROVIDER=Other" \
            "RCLONE_CONFIG_S3_ACCESS_KEY_ID=${S3_ACCESS_KEY}" \
            "RCLONE_CONFIG_S3_SECRET_ACCESS_KEY=${S3_SECRET_KEY}" \
            "RCLONE_CONFIG_S3_ENDPOINT=${S3_ENDPOINT}" \
            "RCLONE_CONFIG_S3_REGION=${S3_REGION}" \
            rclone sync "$LOCAL_DIR" "$REMOTE" \
            --include 'bbs-backup-*.tar.gz' \
            --transfers 2 -v 2>&1

        EXIT_CODE=$?
        if [ $EXIT_CODE -eq 0 ]; then
            echo "OK"
        fi
        exit $EXIT_CODE
        ;;

    install-gate)
        # Install the bbs-ssh-gate script to /usr/local/bin
        # Usage: bbs-ssh-helper install-gate
        BBS_DIR="/var/www/bbs"
        GATE_SRC="$BBS_DIR/bin/bbs-ssh-gate"
        GATE_DST="/usr/local/bin/bbs-ssh-gate"

        if [ ! -f "$GATE_SRC" ]; then
            echo "Error: gate script not found at $GATE_SRC"
            exit 1
        fi

        cp "$GATE_SRC" "$GATE_DST"
        chmod 755 "$GATE_DST"
        chown root:root "$GATE_DST"
        echo "Installed bbs-ssh-gate to $GATE_DST"

        # Ensure sshd accepts legacy ssh-rsa host key algorithm for older clients
        # (CentOS 6 with OpenSSH 5.3 cannot negotiate modern algorithms)
        SSHD_LEGACY="/etc/ssh/sshd_config.d/bbs-legacy-compat.conf"
        SSHD_CONF_DIR="/etc/ssh/sshd_config.d"
        if [ -d "$SSHD_CONF_DIR" ] && [ ! -f "$SSHD_LEGACY" ]; then
            cat > "$SSHD_LEGACY" <<'SSHEOF'
# Added by BBS to support agents on older OS with legacy SSH clients
HostKeyAlgorithms +ssh-rsa
PubkeyAcceptedAlgorithms +ssh-rsa
SSHEOF
            chmod 644 "$SSHD_LEGACY"
            # Validate config before restarting
            if sshd -t 2>/dev/null; then
                systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null || true
                echo "Enabled legacy SSH compatibility"
            else
                rm -f "$SSHD_LEGACY"
                echo "Warning: sshd config invalid, removed legacy compat"
            fi
        fi
        echo "OK"
        ;;

    update-all-keys)
        # Regenerate authorized_keys for all bbs-* users to use the gate dispatcher.
        # Reads the existing public key from each user's authorized_keys file.
        # Usage: bbs-ssh-helper update-all-keys
        UPDATED=0
        SKIPPED=0

        for USERNAME in $(awk -F: '$1 ~ /^bbs-/ {print $1}' /etc/passwd); do
            HOME_DIR=$(getent passwd "$USERNAME" | cut -d: -f6)
            AK_FILE="$HOME_DIR/.ssh/authorized_keys"

            if [ ! -f "$AK_FILE" ]; then
                echo "  $USERNAME: no authorized_keys -- skipping"
                SKIPPED=$((SKIPPED + 1))
                continue
            fi

            # Extract the public key (everything after the last ",restrict " prefix)
            PUBLIC_KEY=$(sed 's/^.*,restrict //' "$AK_FILE" | head -1)

            if [ -z "$PUBLIC_KEY" ]; then
                echo "  $USERNAME: could not extract public key -- skipping"
                SKIPPED=$((SKIPPED + 1))
                continue
            fi

            # Write new authorized_keys with gate dispatcher
            RESTRICT_CMD="command=\"/usr/local/bin/bbs-ssh-gate $HOME_DIR\",restrict"
            echo "$RESTRICT_CMD $PUBLIC_KEY" > "$AK_FILE"
            chmod 600 "$AK_FILE"
            chown "$USERNAME":"$USERNAME" "$AK_FILE"

            # Create catalog log directory with setgid
            CATALOG_DIR="$HOME_DIR/.catalog-logs"
            mkdir -p "$CATALOG_DIR"
            chown "$USERNAME":www-data "$CATALOG_DIR"
            chmod 2770 "$CATALOG_DIR"

            echo "  $USERNAME: updated"
            UPDATED=$((UPDATED + 1))
        done

        echo "Updated: $UPDATED, Skipped: $SKIPPED"
        echo "OK"
        ;;

    update-storage-paths)
        # Write extra --restrict-to-path entries for a user's non-default storage locations.
        # Usage: bbs-ssh-helper update-storage-paths <home_dir> [path1] [path2] ...
        # If no paths given, removes the .storage-paths file.
        HOME_DIR="${2:-}"

        if [ -z "$HOME_DIR" ]; then
            echo "Usage: bbs-ssh-helper update-storage-paths <home_dir> [path1] [path2] ..."
            exit 1
        fi

        PATHS_FILE="$HOME_DIR/.storage-paths"

        # Ensure home directory exists (may not if user creation used a different path)
        if [ ! -d "$HOME_DIR" ]; then
            mkdir -p "$HOME_DIR"
        fi

        if [ $# -le 2 ]; then
            # No extra paths — remove the file if it exists
            rm -f "$PATHS_FILE"
        else
            # Write each extra path (arguments 3+)
            > "$PATHS_FILE"
            shift 2
            for P in "$@"; do
                echo "$P" >> "$PATHS_FILE"
            done
        fi

        # Ensure correct ownership (user can read, www-data can write)
        if [ -f "$PATHS_FILE" ]; then
            OWNER=$(stat -c '%U' "$HOME_DIR")
            chown "$OWNER":www-data "$PATHS_FILE"
            chmod 640 "$PATHS_FILE"
        fi

        echo "OK"
        ;;

    update-allowed-paths)
        # Write allowed storage location paths to /etc/bbs/allowed-storage-paths.
        # Usage: bbs-ssh-helper update-allowed-paths [path1] [path2] ...
        CONFIG_DIR="/etc/bbs"
        CONFIG_FILE="$CONFIG_DIR/allowed-storage-paths"

        mkdir -p "$CONFIG_DIR"

        if [ $# -le 1 ]; then
            rm -f "$CONFIG_FILE"
        else
            > "$CONFIG_FILE"
            shift 1
            for P in "$@"; do
                echo "$P" >> "$CONFIG_FILE"
            done
        fi

        [ -f "$CONFIG_FILE" ] && chmod 644 "$CONFIG_FILE"
        echo "OK"
        ;;

    fix-download-perms)
        # Fix permissions on a download temp directory so www-data can read it
        # Usage: bbs-ssh-helper fix-download-perms <tmpdir>
        TMPDIR="${2:-}"

        if [ -z "$TMPDIR" ]; then
            echo "Usage: bbs-ssh-helper fix-download-perms <tmpdir>"
            exit 1
        fi

        # Safety: tmpdir must be under /tmp
        if [[ ! "$TMPDIR" =~ ^/tmp/bbs-download- ]]; then
            echo "Error: tmpdir must be under /tmp/bbs-download-*"
            exit 1
        fi

        if [ -d "$TMPDIR" ]; then
            chgrp -R www-data "$TMPDIR"
            find "$TMPDIR" -type d -exec chmod 770 {} +
            find "$TMPDIR" -type f -exec chmod 660 {} +
        fi
        echo "OK"
        ;;

    *)
        echo "Usage: bbs-ssh-helper {create-user|create-repo-dir|borg-init|verify-repo|borg-extract|fix-repo-perms|fix-download-perms|delete-user|install-gate|update-all-keys|rclone-sync|rclone-restore|get-size|delete-storage|clear-borg-cache|update-storage-paths|update-allowed-paths} [args...]"
        exit 1
        ;;
esac
