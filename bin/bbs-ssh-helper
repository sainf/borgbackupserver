#!/usr/bin/env bash
#
# BBS SSH Helper — runs as root via sudo to manage Unix users for borg SSH access.
#
# Usage:
#   bbs-ssh-helper create-user <username> <home_dir> <public_key>
#   bbs-ssh-helper create-repo-dir <repo_dir>
#   bbs-ssh-helper delete-user <username>
#
# Install:
#   cp bin/bbs-ssh-helper /usr/local/bin/bbs-ssh-helper
#   chmod 755 /usr/local/bin/bbs-ssh-helper
#   echo "www-data ALL=(root) NOPASSWD: /usr/local/bin/bbs-ssh-helper, /var/www/bbs/bin/bbs-update" > /etc/sudoers.d/bbs-ssh-helper
#
set -euo pipefail

ACTION="${1:-}"

case "$ACTION" in
    create-user)
        USERNAME="${2:-}"
        HOME_DIR="${3:-}"
        PUBLIC_KEY="${4:-}"

        if [ -z "$USERNAME" ] || [ -z "$HOME_DIR" ] || [ -z "$PUBLIC_KEY" ]; then
            echo "Usage: bbs-ssh-helper create-user <username> <home_dir> <public_key>"
            exit 1
        fi

        # Validate username format (must start with bbs-)
        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Create home directory if needed
        mkdir -p "$HOME_DIR"

        # Create user with no password, no login shell, home at storage path
        if id "$USERNAME" &>/dev/null; then
            echo "User $USERNAME already exists"
        else
            useradd --system --shell /bin/sh --home-dir "$HOME_DIR" --no-create-home "$USERNAME"
            echo "Created user: $USERNAME"
        fi

        # Set ownership: user owns, www-data group for server-side borg operations (init, prune, compact)
        chown "$USERNAME":www-data "$HOME_DIR"
        chmod 750 "$HOME_DIR"

        # Configure SSH authorized_keys with borg serve restriction
        SSH_DIR="$HOME_DIR/.ssh"
        mkdir -p "$SSH_DIR"
        chmod 700 "$SSH_DIR"

        AUTHORIZED_KEYS="$SSH_DIR/authorized_keys"
        RESTRICT_CMD="command=\"borg serve --append-only --restrict-to-path $HOME_DIR\",restrict"

        echo "$RESTRICT_CMD $PUBLIC_KEY" > "$AUTHORIZED_KEYS"
        chmod 600 "$AUTHORIZED_KEYS"
        chown -R "$USERNAME":"$USERNAME" "$SSH_DIR"

        echo "OK"
        ;;

    create-repo-dir)
        REPO_DIR="${2:-}"

        if [ -z "$REPO_DIR" ]; then
            echo "Usage: bbs-ssh-helper create-repo-dir <repo_dir>"
            exit 1
        fi

        # Safety: only create under /var/bbs
        if [[ ! "$REPO_DIR" =~ ^/var/bbs/ ]]; then
            echo "Error: repo dir must be under /var/bbs/"
            exit 1
        fi

        mkdir -p "$REPO_DIR"
        # Find the bbs-* user who owns the parent directory
        PARENT_OWNER=$(stat -c '%U' "$(dirname "$REPO_DIR")")
        chown "$PARENT_OWNER":www-data "$REPO_DIR"
        chmod 770 "$REPO_DIR"
        echo "OK"
        ;;

    borg-extract)
        # Run borg extract as the repo-owning user
        # Usage: bbs-ssh-helper borg-extract <username> <tmpdir> <passphrase> <repo::archive> [paths...]
        USERNAME="${2:-}"
        TMPDIR="${3:-}"
        PASSPHRASE="${4:-}"
        shift 4 2>/dev/null || true

        if [ -z "$USERNAME" ] || [ -z "$TMPDIR" ] || [ $# -eq 0 ]; then
            echo "Usage: bbs-ssh-helper borg-extract <username> <tmpdir> <passphrase> <repo::archive> [paths...]"
            exit 1
        fi

        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        # Safety: tmpdir must be under /tmp
        if [[ ! "$TMPDIR" =~ ^/tmp/ ]]; then
            echo "Error: tmpdir must be under /tmp/"
            exit 1
        fi

        # Ensure tmpdir exists and is writable by the user
        mkdir -p "$TMPDIR"
        chown "$USERNAME":www-data "$TMPDIR"
        chmod 770 "$TMPDIR"

        # Per-user borg cache dir (matches scheduler.php and bbs-update)
        BORG_DIR="/var/bbs/cache/$USERNAME"
        mkdir -p "$BORG_DIR"
        chown "$USERNAME":"$USERNAME" "$BORG_DIR"

        # Run borg extract as the repo-owning user
        cd "$TMPDIR"
        sudo -u "$USERNAME" \
            BORG_PASSPHRASE="$PASSPHRASE" \
            BORG_UNKNOWN_UNENCRYPTED_REPO_ACCESS_IS_OK=yes \
            BORG_BASE_DIR="$BORG_DIR" \
            HOME="$BORG_DIR" \
            borg extract "$@" 2>&1

        EXIT_CODE=$?

        # Make extracted files readable by www-data for tar/streaming
        chown -R "$USERNAME":www-data "$TMPDIR"
        chmod -R g+rX "$TMPDIR"

        exit $EXIT_CODE
        ;;

    fix-repo-perms)
        REPO_DIR="${2:-}"
        USERNAME="${3:-}"

        if [ -z "$REPO_DIR" ] || [ -z "$USERNAME" ]; then
            echo "Usage: bbs-ssh-helper fix-repo-perms <repo_dir> <username>"
            exit 1
        fi

        # Safety checks
        if [[ ! "$REPO_DIR" =~ ^/var/bbs/ ]]; then
            echo "Error: repo dir must be under /var/bbs/"
            exit 1
        fi
        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: username must match bbs-[a-z0-9_-]+"
            exit 1
        fi

        if [ -d "$REPO_DIR" ]; then
            chown -R "$USERNAME":www-data "$REPO_DIR"
            chmod 770 "$REPO_DIR"
        fi
        echo "OK"
        ;;

    delete-user)
        USERNAME="${2:-}"

        if [ -z "$USERNAME" ]; then
            echo "Usage: bbs-ssh-helper delete-user <username>"
            exit 1
        fi

        # Safety: only delete bbs- prefixed users
        if [[ ! "$USERNAME" =~ ^bbs-[a-z0-9_-]+$ ]]; then
            echo "Error: will only delete users matching bbs-[a-z0-9_-]+"
            exit 1
        fi

        if id "$USERNAME" &>/dev/null; then
            userdel "$USERNAME" 2>/dev/null || true
            echo "Deleted user: $USERNAME"
        else
            echo "User $USERNAME does not exist"
        fi

        echo "OK"
        ;;

    *)
        echo "Usage: bbs-ssh-helper {create-user|create-repo-dir|borg-extract|fix-repo-perms|delete-user} [args...]"
        exit 1
        ;;
esac
