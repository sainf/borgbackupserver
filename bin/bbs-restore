#!/usr/bin/env bash
#
# BBS Restore — restores BBS from a backup created by bbs-backup.
#
# Usage:
#   sudo /var/www/bbs/bin/bbs-restore <backup.tar.gz>
#
# Prerequisites:
#   - Run bbs-install first on a fresh server to set up Apache, PHP, MySQL, etc.
#   - The backup file must be a tar.gz created by bbs-backup.
#
# Restores:
#   - config/.env (APP_KEY, DB credentials)
#   - MySQL database (all tables except catalogs)
#   - SSH host keys (prevents "host key changed" errors for agents)
#   - ClickHouse catalog data (file-level search index)
#   - Sudoers and cron configuration
#   - Unix users for SSH access
#
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${BOLD}$1${NC}"; }
ok()    { echo -e "  ${GREEN}✓${NC} $1"; }
warn()  { echo -e "  ${YELLOW}⚠${NC} $1"; }
error() { echo -e "  ${RED}✗${NC} $1"; }

AUTO_YES=false
BACKUP_FILE=""
BBS_DIR="/var/www/bbs"

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --yes) AUTO_YES=true ;;
        *) BACKUP_FILE="$arg" ;;
    esac
done

if [ -z "$BACKUP_FILE" ]; then
    echo "Usage: sudo bbs-restore [--yes] <backup.tar.gz>"
    exit 1
fi

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: must run as root (use sudo)"
    exit 1
fi

if [ ! -f "$BACKUP_FILE" ]; then
    echo "Error: backup file not found: $BACKUP_FILE"
    exit 1
fi

if [ ! -d "$BBS_DIR" ]; then
    echo "Error: BBS is not installed at $BBS_DIR"
    echo "Run bbs-install first, then re-run this restore script."
    exit 1
fi

# Extract to temp dir
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

info "Extracting backup..."
tar -xzf "$BACKUP_FILE" -C "$TMPDIR"

# Verify minimum required contents
for f in dump.sql env version; do
    if [ ! -f "$TMPDIR/$f" ]; then
        error "Backup is missing '$f' — not a valid bbs-backup archive"
        exit 1
    fi
done

BACKUP_VERSION=$(cat "$TMPDIR/version" | tr -d '[:space:]')
CURRENT_VERSION=$(cat "$BBS_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")

echo ""
info "Backup version:  $BACKUP_VERSION"
info "Current version: $CURRENT_VERSION"
echo ""

# Step 1: Checkout matching version
if [ ! -d "$BBS_DIR/.git" ]; then
    info "[1/7] No git repo (Docker) — skipping version checkout"
    ok "Using installed version v${CURRENT_VERSION}"
elif [ "$BACKUP_VERSION" != "unknown" ] && [ "$BACKUP_VERSION" != "$CURRENT_VERSION" ]; then
    info "[1/7] Checking out version v${BACKUP_VERSION} to match backup..."
    git config --global --add safe.directory "$BBS_DIR" 2>/dev/null || true
    git -C "$BBS_DIR" fetch --all --tags --force 2>/dev/null
    if git -C "$BBS_DIR" rev-parse "v${BACKUP_VERSION}" &>/dev/null; then
        git -C "$BBS_DIR" checkout "v${BACKUP_VERSION}" -- . 2>/dev/null || \
            git -C "$BBS_DIR" reset --hard "v${BACKUP_VERSION}"
        ok "Code set to v${BACKUP_VERSION}"
    else
        warn "Tag v${BACKUP_VERSION} not found, continuing with current code"
    fi
else
    info "[1/7] Version matches, no checkout needed"
    ok "v${BACKUP_VERSION}"
fi

# Step 2: Restore .env
info "[2/7] Restoring config/.env..."

# Save current DB credentials before overwriting (the running MySQL may have different creds
# than the backup's .env, e.g., Docker container with random password vs bare-metal backup)
SAVED_DB_HOST=""
SAVED_DB_NAME=""
SAVED_DB_USER=""
SAVED_DB_PASS=""
if [ -f "$BBS_DIR/config/.env" ]; then
    SAVED_DB_HOST=$(grep '^DB_HOST=' "$BBS_DIR/config/.env" | cut -d= -f2-)
    SAVED_DB_NAME=$(grep '^DB_NAME=' "$BBS_DIR/config/.env" | cut -d= -f2-)
    SAVED_DB_USER=$(grep '^DB_USER=' "$BBS_DIR/config/.env" | cut -d= -f2-)
    SAVED_DB_PASS=$(grep '^DB_PASS=' "$BBS_DIR/config/.env" | cut -d= -f2-)
fi

if [ -f "$BBS_DIR/config/.env" ]; then
    if [ "$AUTO_YES" = true ]; then
        REPLY="y"
    else
        echo -n "  Overwrite existing .env? [y/N] "
        read -r REPLY
    fi
    if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
        echo "  Skipping .env restore (keeping existing)"
    else
        cp "$TMPDIR/env" "$BBS_DIR/config/.env"
        chmod 600 "$BBS_DIR/config/.env"
        chown www-data:www-data "$BBS_DIR/config/.env"
        ok "Restored .env"
    fi
else
    cp "$TMPDIR/env" "$BBS_DIR/config/.env"
    chmod 600 "$BBS_DIR/config/.env"
    chown www-data:www-data "$BBS_DIR/config/.env"
    ok "Restored .env"
fi

# Read DB credentials from the (possibly restored) .env
ENV_FILE="$BBS_DIR/config/.env"
DB_HOST=$(grep '^DB_HOST=' "$ENV_FILE" | cut -d= -f2-)
DB_NAME=$(grep '^DB_NAME=' "$ENV_FILE" | cut -d= -f2-)
DB_USER=$(grep '^DB_USER=' "$ENV_FILE" | cut -d= -f2-)
DB_PASS=$(grep '^DB_PASS=' "$ENV_FILE" | cut -d= -f2-)

# If the restored .env has different DB creds, try the current running creds first
# (common in Docker where the backup is from a different server)
if [ -n "$SAVED_DB_PASS" ] && [ "$SAVED_DB_PASS" != "$DB_PASS" ]; then
    if mysql -h "${SAVED_DB_HOST:-localhost}" -u "$SAVED_DB_USER" -p"$SAVED_DB_PASS" -e "SELECT 1" &>/dev/null; then
        warn "Backup .env has different DB password — using current running credentials"
        DB_HOST="$SAVED_DB_HOST"
        DB_NAME="$SAVED_DB_NAME"
        DB_USER="$SAVED_DB_USER"
        DB_PASS="$SAVED_DB_PASS"
        # Update .env with working DB credentials
        sed -i "s|^DB_HOST=.*|DB_HOST=${DB_HOST}|" "$ENV_FILE"
        sed -i "s|^DB_NAME=.*|DB_NAME=${DB_NAME}|" "$ENV_FILE"
        sed -i "s|^DB_USER=.*|DB_USER=${DB_USER}|" "$ENV_FILE"
        sed -i "s|^DB_PASS=.*|DB_PASS=${DB_PASS}|" "$ENV_FILE"
    fi
fi

if [ -z "$DB_NAME" ] || [ -z "$DB_USER" ]; then
    error "Could not read DB credentials from .env"
    exit 1
fi

# Step 3: Import MySQL dump
info "[3/7] Importing MySQL database..."
if [ "$AUTO_YES" = true ]; then
    REPLY="y"
else
    echo -n "  This will DROP and recreate all tables in '$DB_NAME'. Continue? [y/N] "
    read -r REPLY
fi
if [[ ! "$REPLY" =~ ^[Yy]$ ]]; then
    echo "  Skipping database import"
else
    # Drop and recreate database to ensure clean state
    mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" \
        -e "DROP DATABASE IF EXISTS \`$DB_NAME\`; CREATE DATABASE \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" 2>/dev/null
    mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" \
        "$DB_NAME" < "$TMPDIR/dump.sql" 2>/dev/null
    ok "Database imported"

    # Clear stale job queue — old queued/running jobs are meaningless on a restored system
    mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" \
        -e "DELETE FROM backup_jobs WHERE status IN ('queued', 'sent', 'running')" 2>/dev/null
    ok "Cleared stale job queue"

    # Enable maintenance mode — prevents scheduler from queuing new jobs before repos are restored
    mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" \
        -e "INSERT INTO settings (\`key\`, \`value\`) VALUES ('maintenance_mode', '1') ON DUPLICATE KEY UPDATE \`value\` = '1'" 2>/dev/null
    ok "Maintenance mode enabled (disable in Settings after verifying repos)"

    # When running non-interactively, reset admin password so the caller can log in
    if [ "$AUTO_YES" = true ]; then
        NEW_PASS=$(openssl rand -base64 12 | tr -d '/+=' | head -c 16)
        # Use PHP to both hash the password and update the DB (avoids bash $-escaping issues with bcrypt hashes)
        php -r "
            \$pass = \$argv[1];
            \$hash = password_hash(\$pass, PASSWORD_DEFAULT);
            \$pdo = new PDO('mysql:host=' . (\$argv[2] ?: 'localhost') . ';dbname=' . \$argv[3], \$argv[4], \$argv[5]);
            \$stmt = \$pdo->prepare('UPDATE users SET password_hash = ? WHERE username = ?');
            \$stmt->execute([\$hash, 'admin']);
        " "$NEW_PASS" "${DB_HOST:-localhost}" "$DB_NAME" "$DB_USER" "$DB_PASS"
        ok "Admin password reset"
        echo "NEW_ADMIN_PASSWORD=$NEW_PASS"
    fi
fi

# Step 4: Restore SSH host keys
info "[4/7] Restoring SSH host keys..."
if [ -d "$TMPDIR/ssh-host-keys" ] && [ "$(ls -A "$TMPDIR/ssh-host-keys" 2>/dev/null)" ]; then
    cp "$TMPDIR/ssh-host-keys"/ssh_host_*_key /etc/ssh/ 2>/dev/null || true
    cp "$TMPDIR/ssh-host-keys"/ssh_host_*_key.pub /etc/ssh/ 2>/dev/null || true
    chmod 600 /etc/ssh/ssh_host_*_key 2>/dev/null || true
    chmod 644 /etc/ssh/ssh_host_*_key.pub 2>/dev/null || true

    # Also persist to Docker volume path if it exists
    if [ -d /var/bbs ]; then
        mkdir -p /var/bbs/.ssh-host-keys
        cp "$TMPDIR/ssh-host-keys"/ssh_host_* /var/bbs/.ssh-host-keys/ 2>/dev/null || true
    fi

    # Restart sshd to pick up restored keys
    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null || true
    ok "SSH host keys restored"
else
    warn "No SSH host keys in backup (older backup format)"
fi

# Step 5: Restore ClickHouse catalogs
info "[5/7] Restoring ClickHouse catalogs..."
if [ -f "$TMPDIR/clickhouse-file-catalog.csv" ]; then
    if command -v clickhouse-client &>/dev/null && curl -sf http://localhost:8123/ping >/dev/null 2>&1; then
        # Ensure database and schema exist
        clickhouse-client --query "CREATE DATABASE IF NOT EXISTS bbs" 2>/dev/null || true
        if [ -f "$BBS_DIR/schema-clickhouse.sql" ]; then
            clickhouse-client -d bbs --multiquery < "$BBS_DIR/schema-clickhouse.sql" 2>/dev/null || true
        fi
        # Clear existing catalog data before import
        clickhouse-client -d bbs --query "TRUNCATE TABLE IF EXISTS file_catalog" 2>/dev/null || true
        # Import CSV data
        clickhouse-client -d bbs --query \
            "INSERT INTO file_catalog FORMAT CSVWithNames" \
            < "$TMPDIR/clickhouse-file-catalog.csv" 2>/dev/null || true
        ROWS=$(wc -l < "$TMPDIR/clickhouse-file-catalog.csv")
        ROWS=$((ROWS - 1))  # subtract header
        ok "Restored $ROWS catalog rows"
    else
        warn "ClickHouse not running — catalog will rebuild on next backup"
    fi
else
    warn "No ClickHouse data in backup (older backup format or empty catalog)"
fi

# Step 6: Restore sudoers and cron
info "[6/7] Restoring system config..."
if [ -d "$TMPDIR/sudoers" ]; then
    for sf in "$TMPDIR/sudoers"/*; do
        [ -f "$sf" ] || continue
        cp "$sf" "/etc/sudoers.d/$(basename "$sf")"
        chmod 440 "/etc/sudoers.d/$(basename "$sf")"
    done
    ok "Sudoers restored"
else
    # Ensure defaults exist even without backup copy
    echo "www-data ALL=(root) NOPASSWD: /usr/local/bin/bbs-ssh-helper, $BBS_DIR/bin/bbs-update" > /etc/sudoers.d/bbs-ssh-helper
    echo "www-data ALL=(bbs-*) NOPASSWD: /usr/bin/borg, /usr/local/bin/borg, /usr/bin/rclone, /usr/bin/env" > /etc/sudoers.d/bbs-borg
    chmod 440 /etc/sudoers.d/bbs-ssh-helper /etc/sudoers.d/bbs-borg
    ok "Sudoers created (defaults)"
fi

if [ -f "$TMPDIR/cron" ]; then
    cp "$TMPDIR/cron" /etc/cron.d/bbs-scheduler
    chmod 644 /etc/cron.d/bbs-scheduler
    ok "Cron restored"
fi

# Step 7: Recreate Unix users
info "[7/7] Recreating Unix users for SSH access..."

# Get storage_path from settings
STORAGE_PATH=$(mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" \
    -N -e "SELECT \`value\` FROM settings WHERE \`key\` = 'storage_path'" 2>/dev/null || true)

if [ -z "$STORAGE_PATH" ]; then
    warn "No storage_path in settings, skipping user recreation"
else
    # Query agents with SSH users
    AGENTS=$(mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" \
        -N -e "SELECT id, ssh_unix_user, ssh_public_key FROM agents WHERE ssh_unix_user IS NOT NULL AND ssh_public_key IS NOT NULL" 2>/dev/null || true)

    if [ -z "$AGENTS" ]; then
        echo "  No agents with SSH users found"
    else
        COUNT=0
        while IFS=$'\t' read -r AGENT_ID UNIX_USER PUBLIC_KEY; do
            [ -z "$UNIX_USER" ] && continue
            HOME_DIR="${STORAGE_PATH%/}/${AGENT_ID}"
            /usr/local/bin/bbs-ssh-helper create-user "$UNIX_USER" "$HOME_DIR" "$PUBLIC_KEY" >/dev/null 2>&1 || true
            COUNT=$((COUNT + 1))
        done <<< "$AGENTS"
        ok "Recreated $COUNT Unix user(s)"
    fi
fi

# Run bbs-update-run to fix all permissions (skip bbs-update's git pull in Docker)
info "Running post-restore permission fixes..."
if [ -f "$BBS_DIR/bin/bbs-update-run" ]; then
    bash "$BBS_DIR/bin/bbs-update-run" "$BBS_DIR" 2>&1 | sed 's/^/  /'
else
    "$BBS_DIR/bin/bbs-update" "$BBS_DIR" 2>&1 | sed 's/^/  /'
fi

echo ""
info "═══════════════════════════════════════════════════"
info "  BBS Restore Complete"
info "═══════════════════════════════════════════════════"
echo ""
echo "  Restored from: $(basename "$BACKUP_FILE")"
echo "  Version: $BACKUP_VERSION"
echo ""
echo "  Contents restored:"
echo "    • MySQL database"
echo "    • config/.env"
[ -d "$TMPDIR/ssh-host-keys" ] && echo "    • SSH host keys"
[ -f "$TMPDIR/clickhouse-file-catalog.csv" ] && echo "    • ClickHouse catalogs"
[ -d "$TMPDIR/sudoers" ] && echo "    • Sudoers config"
[ -f "$TMPDIR/cron" ] && echo "    • Cron scheduler"
echo ""
if [ "$BACKUP_VERSION" != "$CURRENT_VERSION" ] && [ "$BACKUP_VERSION" != "unknown" ]; then
    echo "  To upgrade to latest version, run:"
    echo "    sudo $BBS_DIR/bin/bbs-update"
    echo ""
fi
